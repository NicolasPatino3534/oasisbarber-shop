rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catalogo: lectura publica, escritura solo para admins con sesion iniciada
    match /servicios/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /profesionales/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Turnos
    match /turnos/{docId} {
      // Lectura publica: necesaria para verificar slots disponibles
      // y para que los clientes busquen sus propias reservas por telefono
      allow read: if true;

      // Creacion publica con validacion de estructura minima
      allow create: if request.resource.data.keys().hasAll([
                         'professionalId', 'date', 'time', 'clientName'
                       ])
                    && request.resource.data.clientName   is string
                    && request.resource.data.clientName.size() > 0
                    && request.resource.data.clientName.size() <= 100
                    && request.resource.data.date         is string
                    && request.resource.data.time         is string
                    && request.resource.data.professionalId is string;

      // Modificacion y eliminacion solo para el admin autenticado
      allow update, delete: if request.auth != null;
    }

    // Bloquear cualquier otra coleccion
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
